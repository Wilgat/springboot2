#!/bin/sh

# ────────────────────────────────────────────────
#  springboot2 – version 1.0.0
#  One-command installer & launcher:
#    • Installs SDKMAN! if missing
#    • Installs Java 8 (Amazon Corretto)
#    • Installs latest compatible Maven (3.9.13)
#    • Creates & runs minimal Spring Boot 2.7.18 Hello World
# ────────────────────────────────────────────────

VERSION="1.0.0"

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

# ────────────────────────────────────────────────
# Installation path logic (like ciao)
# ────────────────────────────────────────────────

if [ "$(id -u)" -eq 0 ]; then
    INSTALL_DIR="/usr/local/bin"
    INSTALL_PATH="$INSTALL_DIR/springboot2"
    NEEDS_SUDO=false
else
    INSTALL_DIR="${HOME}/.local/bin"
    INSTALL_PATH="$INSTALL_DIR/springboot2"
    NEEDS_SUDO=true
fi

# ────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────

is_installed() {
    [ -f "$INSTALL_PATH" ] && [ -x "$INSTALL_PATH" ]
}

in_path() {
    case ":${PATH}:" in
        *:"${INSTALL_DIR}":*) return 0 ;;
        *) return 1 ;;
    esac
}

add_to_bashrc() {
    local bashrc="${HOME}/.bashrc"
    local line="export PATH=\"\$HOME/.local/bin:\$PATH\""

    if [ -f "$bashrc" ] && grep -qF "$line" "$bashrc" 2>/dev/null; then
        return
    fi

    echo "" >> "$bashrc"
    echo "# Added by springboot2 installer" >> "$bashrc"
    echo "$line" >> "$bashrc"
    echo "${YELLOW}→ Added ~/.local/bin to PATH in ~/.bashrc${NC}"
}

# ────────────────────────────────────────────────
# Self-install logic
# ────────────────────────────────────────────────

show_install_suggestion() {
    if is_installed; then
        return
    fi

    echo ""
    echo "${YELLOW}Note: 'springboot2' is not installed yet${NC}"
    echo ""

    if $NEEDS_SUDO; then
        echo "Recommended: ${GREEN}sudo curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2 | sudo sh${NC}"
    else
        echo "Recommended: ${GREEN}curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2 | sh${NC}"
    fi

    echo ""

    local should_install=false

    if [ -t 0 ] && [ -t 1 ]; then
        printf "Install now? (y/N): "
        read -r answer </dev/tty 2>/dev/null || read -r answer
        case "$answer" in
            [Yy]*) should_install=true ;;
            *) echo "Skipping installation."; return ;;
        esac
    else
        echo "Non-interactive → installing automatically..."
        should_install=true
    fi

    if ! $should_install; then return; fi

    echo "Installing to: ${GREEN}$INSTALL_PATH${NC}"

    mkdir -p "$INSTALL_DIR" 2>/dev/null || {
        echo "${RED}Cannot create $INSTALL_DIR${NC}" >&2
        exit 1
    }

    TMP_SCRIPT="/tmp/springboot2_install_$$"
    if ! curl -fsSL "https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2" -o "$TMP_SCRIPT"; then
        echo "${RED}Download failed${NC}" >&2
        rm -f "$TMP_SCRIPT" 2>/dev/null
        exit 1
    fi

    chmod 755 "$TMP_SCRIPT" || {
        echo "${RED}chmod failed${NC}" >&2
        rm -f "$TMP_SCRIPT"
        exit 1
    }

    if cp "$TMP_SCRIPT" "$INSTALL_PATH" 2>/dev/null; then
        echo "${GREEN}Installed successfully!${NC}"
        rm -f "$TMP_SCRIPT"

        if $NEEDS_SUDO; then
            echo "Run ${GREEN}springboot2${NC} from anywhere."
        else
            if ! in_path; then
                add_to_bashrc
                echo ""
                echo "${YELLOW}Important:${NC} ~/.local/bin added to ~/.bashrc."
                echo "Run one of these now:"
                echo "  ${GREEN}. ~/.bashrc${NC}"
                echo "  ${GREEN}source ~/.bashrc${NC}"
            else
                echo "Run ${GREEN}springboot2${NC}."
            fi
        fi

        exit 0
    else
        echo "${RED}Failed to write to $INSTALL_PATH${NC}" >&2
        echo "Try with proper permissions."
        rm -f "$TMP_SCRIPT"
        exit 1
    fi
}

# ────────────────────────────────────────────────
# Help
# ────────────────────────────────────────────────

show_help() {
    cat << 'EOF'
springboot2 – version 1.0.0

One-command tool to setup & run legacy Spring Boot 2.7 environment:

Usage:
  springboot2               Install tools (if needed) → create → build → run Hello World app
  springboot2 version       Show version
  springboot2 help          This help

What it does (first run or when missing):
  • Installs SDKMAN! if not present
  • Installs Java 8 (Amazon Corretto)
  • Installs Maven 3.9.13
  • Creates ~/spring-boot-hello-sdkman (minimal Spring Boot 2.7.18 project)
  • Builds & runs it[](http://localhost:8080)

EOF
}

# ────────────────────────────────────────────────
# Main logic – setup & run Spring Boot demo
# ────────────────────────────────────────────────

COMMAND="run"

while [ $# -gt 0 ]; do
    case "$1" in
        version) COMMAND="version"; shift ;;
        help)    COMMAND="help";    shift ;;
        *)       echo "${RED}Unknown argument: $1${NC}" >&2
                 echo "Try: springboot2 help"
                 exit 1 ;;
    esac
done

# Try to install if not present
show_install_suggestion

case "$COMMAND" in
    version)
        echo "springboot2 version $VERSION"
        exit 0
        ;;

    help)
        show_help
        exit 0
        ;;

    run) : ;;  # continue below
    *)
        echo "${RED}Invalid command${NC}" >&2
        exit 1
        ;;
esac

# ────────────────────────────────────────────────
# From here: the actual setup + run logic
# ────────────────────────────────────────────────

echo ""
echo "=============================================================="
echo " springboot2 – SDKMAN + Java 8 + Maven + Spring Boot 2.7 setup"
echo "=============================================================="
echo ""

# 1. SDKMAN!
echo "→ Checking SDKMAN..."
if [ -d "$HOME/.sdkman" ] && command -v sdk >/dev/null 2>&1; then
    echo "   Already installed."
else
    echo "   Installing SDKMAN..."
    curl -s "https://get.sdkman.io" | bash
    [ $? -ne 0 ] && { echo "${RED}SDKMAN install failed${NC}"; exit 1; }

    source "$HOME/.sdkman/bin/sdkman-init.sh" 2>/dev/null || {
        echo "${YELLOW}Note: Open new terminal after this script finishes${NC}"
    }
fi

if ! type sdk >/dev/null 2>&1; then
    echo "${RED}sdk command still not found — try new terminal${NC}"
    exit 1
fi

sdk version | head -n 1

# 2. Java 8 – Amazon Corretto (use a recent 8.x version – 8.432 or later if available)
echo ""
echo "→ Installing Java 8 (Amazon Corretto)..."

# Note 2026: 8.0.432-amzn or similar – adjust if SDKMAN has newer identifier
sdk install java 8.0.432-amzn </dev/null || {
    echo "${RED}Failed to install Java 8 Corretto${NC}"
    echo "Check 'sdk list java' for available Corretto 8 versions"
    exit 1
}

sdk default java 8.0.432-amzn >/dev/null 2>&1
sdk use   java 8.0.432-amzn >/dev/null 2>&1 || true

if ! command -v java >/dev/null 2>&1; then
    echo "${RED}java not found after install${NC}"
    exit 1
fi

java -version 2>&1 | head -n 1

# 3. Maven – latest 3.9.x (compatible with Java 8)
echo ""
echo "→ Installing Maven 3.9.13..."

sdk install maven 3.9.13 </dev/null || {
    echo "${RED}Failed to install Maven 3.9.13${NC}"
    exit 1
}

sdk default maven 3.9.13 >/dev/null 2>&1
sdk use   maven 3.9.13 >/dev/null 2>&1 || true

if ! command -v mvn >/dev/null 2>&1; then
    echo "${RED}mvn not found${NC}"
    exit 1
fi

mvn --version | head -n 3

# 4. Create minimal Spring Boot 2.7.18 project
echo ""
echo "→ Creating minimal Spring Boot 2.7.18 project..."

PROJECT_DIR="$HOME/spring-boot-hello-sdkman"

[ -d "$PROJECT_DIR" ] && {
    echo "   Removing old project folder..."
    rm -rf "$PROJECT_DIR"
}

mkdir -p "$PROJECT_DIR"
cd "$PROJECT_DIR" || exit 1

# pom.xml – Spring Boot 2.7.18 (latest in 2.7 line)
cat > pom.xml << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.example</groupId>
    <artifactId>hello-sdkman</artifactId>
    <version>0.0.1</version>
    <packaging>jar</packaging>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>2.7.18</version>
    </parent>

    <properties>
        <java.version>1.8</java.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
EOF

# Main class
mkdir -p src/main/java/com/example
cat > src/main/java/com/example/HelloApplication.java << 'EOF'
package com.example;

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootApplication
@RestController
public class HelloApplication {

    public static void main(String[] args) {
        SpringApplication.run(HelloApplication.class, args);
    }

    @GetMapping("/")
    public String home() {
        return "Hello from Spring Boot 2.7.18 (Java 8 + Maven via SDKMAN!)";
    }
}
EOF

# application.properties
mkdir -p src/main/resources
cat > src/main/resources/application.properties << 'EOF'
server.port=8080
server.address=0.0.0.0
EOF

echo "   Project created → $PROJECT_DIR"

# 5. Build & run
echo ""
echo "→ Building application..."

mvn clean package -DskipTests || {
    echo "${RED}Build failed${NC}"
    echo "Try manually: cd $PROJECT_DIR && mvn clean package"
    exit 1
}

echo ""
echo "=============================================================="
echo "  Spring Boot app ready!"
echo "  → Open:  http://localhost:8080"
echo "  → Or any IP of this machine"
echo "  Press Ctrl+C to stop"
echo "=============================================================="
echo ""

java -jar target/hello-sdkman-0.0.1.jar