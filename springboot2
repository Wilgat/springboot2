#!/bin/bash

# ────────────────────────────────────────────────
#  springboot2 – version 1.0.9
#  One-command installer + launcher for Spring Boot 2.7.x (last 2.x LTS)
#
#    • Installs itself (~/.local/bin or /usr/local/bin)
#    • Installs SDKMAN! if missing
#    • Installs latest Java 8 Amazon Corretto (8-amzn)
#    • Installs recent Maven (3.9.9)
#    • (Re)creates & runs minimal Spring Boot 2.7.18 Hello World
#
#  Install (user):
#    curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2 | bash
#
#  Install (global):
#    curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2 | sudo bash
#
#  GitHub:   https://github.com/Wilgat/springboot2
# ────────────────────────────────────────────────

APP_NAME="${0##*/}"
APP_VER="1.0.9"

REPO_USER="Wilgat"
REPO_NAME="springboot2"
SCRIPT_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/main/${APP_NAME}"

GLOBAL_BIN="/usr/local/bin"
USER_BIN="${HOME}/.local/bin"

PROJECT_NAME="springboot-${APP_NAME}"
PROJECT_DIR="${HOME}/${PROJECT_NAME}"

JAVA_ID="8-amzn"
MAVEN_VER="3.9.9"
SPRINGBOOT_VER="2.7.18"
ARTIFACT_ID="hello-${APP_NAME}"
CLASS_NAME="HelloApplication"
GROUP_ID="com.example"
VERSION="0.0.1"
JAR_NAME="${ARTIFACT_ID}-${VERSION}.jar"
PORT="8080"
BIND_IP="0.0.0.0"

# Colors
if [[ -t 1 ]]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

# ────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────

die() {
    printf >&2 "${RED}Error: %s${NC}\n" "$*"
    exit 1
}

info()  { printf "${GREEN}→ %s${NC}\n" "$*"; }
warn()  { printf "${YELLOW}⚠  %s${NC}\n" "$*"; }

detect_install_locations() {
    if (( UID == 0 )); then
        IS_ROOT=1
        INSTALL_DIR="${GLOBAL_BIN}"
    else
        IS_ROOT=0
        INSTALL_DIR="${USER_BIN}"
    fi
    INSTALL_PATH="${INSTALL_DIR}/${APP_NAME}"
}

is_installed() {
    if (( IS_ROOT == 1 )); then
        [[ -x "${INSTALL_PATH}" ]]
    else
        [[ -x "${GLOBAL_BIN}/${APP_NAME}" ]] || [[ -x "${USER_BIN}/${APP_NAME}" ]]
    fi
}

in_path() {
    [[ ":${PATH}:" == *":${INSTALL_DIR}:"* ]]
}

add_to_bashrc() {
    local bashrc="${HOME}/.bashrc"
    local line='export PATH="$HOME/.local/bin:$PATH"'

    [[ -f "$bashrc" ]] && grep -qF "$line" "$bashrc" && return 0

    printf '\n# Added by %s installer\n%s\n' "$APP_NAME" "$line" >> "$bashrc" || {
        warn "Could not append to ~/.bashrc"
        return 1
    }

    info "~/.local/bin added to ~/.bashrc"
}

perform_self_install() {
    info "${APP_NAME} not found → installing to ${INSTALL_PATH}"

    mkdir -p "${INSTALL_DIR}" 2>/dev/null || die "Cannot create ${INSTALL_DIR}"

    local tmp
    tmp=$(mktemp "/tmp/${APP_NAME}-install-XXXXXXXX") || die "mktemp failed"

    curl -fsSL "${SCRIPT_URL}" -o "${tmp}" || {
        rm -f "${tmp}"
        die "Download failed: ${SCRIPT_URL}"
    }

    chmod 755 "${tmp}" || die "chmod failed"

    if mv "${tmp}" "${INSTALL_PATH}"; then
        info "Installed to ${INSTALL_PATH}"
    else
        rm -f "${tmp}"
        die "Cannot install to ${INSTALL_PATH} (permission?)"
    fi

    if (( IS_ROOT == 0 )) && ! in_path; then
        add_to_bashrc
        printf '\n'
        warn "Important: ~/.local/bin was not in your PATH."
        printf "          We added it to ~/.bashrc.\n\n"
        printf "          Run one of these now:\n"
        printf "            ${GREEN}. ~/.bashrc${NC}\n"
        printf "            ${GREEN}source ~/.bashrc${NC}\n\n"
        printf "          Then ${APP_NAME} will be available.\n\n"
    fi
}

show_help() {
    cat <<EOF
${APP_NAME} v${APP_VER} — Spring Boot 2.7.x quick setup (last 2.x LTS)

Usage:
  ${APP_NAME}               Setup + create + build + run demo
  ${APP_NAME} help          This help
  ${APP_NAME} version       Show version

What it does:
  • Installs itself if missing
  • Installs SDKMAN!
  • Installs Java 8 Amazon Corretto (latest patch)
  • Installs Maven ${MAVEN_VER}
  • (Re)creates minimal Spring Boot ${SPRINGBOOT_VER} project in ~/${PROJECT_NAME}
  • Builds and runs → http://localhost:${PORT}/

Note: After first SDKMAN install you may need to run
  . "\$HOME/.sdkman/bin/sdkman-init.sh"
or open a new terminal if 'sdk' is not found.

EOF
}

parse_arguments() {
    COMMAND="run"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            help|--help|-h)    COMMAND="help";    shift ;;
            version|--version) COMMAND="version"; shift ;;
            *) warn "Unknown argument: $1"; show_help; exit 1 ;;
        esac
    done
}

setup_sdkman() {
    info "Checking SDKMAN..."

    if [[ -d "${HOME}/.sdkman" ]] && command -v sdk &>/dev/null; then
        info "SDKMAN already installed."
        return 0
    fi

    info "Installing SDKMAN..."
    curl -s "https://get.sdkman.io" | bash || die "SDKMAN install failed"

    # Load in current session
    local init="${HOME}/.sdkman/bin/sdkman-init.sh"
    [[ -s "$init" ]] && . "$init"

    if ! command -v sdk &>/dev/null; then
        warn "sdk command not available yet (common after first install)."
        printf "Please run one of these, then re-execute '%s':\n" "${APP_NAME}"
        printf "  ${GREEN}. \"\$HOME/.sdkman/bin/sdkman-init.sh\"${NC}\n"
        printf "  ${GREEN}. ~/.bashrc${NC}\n"
        printf "  or open a new terminal\n"
        exit 1
    fi

    info "SDKMAN ready."
    sdk version | head -n 1
}

setup_java() {
    info "Setting up Java 8 (Amazon Corretto)..."
    sdk install java "${JAVA_ID}" </dev/null || die "sdk install java failed"
    sdk default java "${JAVA_ID}" &>/dev/null
    sdk use    java "${JAVA_ID}" &>/dev/null || true
    java -version 2>&1 | head -n 1 || die "java not working"
}

setup_maven() {
    info "Setting up Maven ${MAVEN_VER}..."
    sdk install maven "${MAVEN_VER}" </dev/null || die "sdk install maven failed"
    sdk default maven "${MAVEN_VER}" &>/dev/null
    sdk use    maven "${MAVEN_VER}" &>/dev/null || true
    mvn --version | head -n 3 || die "mvn not working"
}

write_file_atomic() {
    local target="$1"
    local tmp
    tmp=$(mktemp "${target}.XXXXXXXX") || die "mktemp failed"

    cat > "${tmp}" || { rm -f "${tmp}"; die "write failed"; }
    mv "${tmp}" "${target}" || { rm -f "${tmp}"; die "mv failed → ${target}"; }
}

setup_springboot_project() {
    info "Preparing Spring Boot ${SPRINGBOOT_VER} demo → ${PROJECT_DIR}"

    [[ -d "${PROJECT_DIR}" ]] && {
        info "Removing old project folder..."
        rm -rf "${PROJECT_DIR}"
    }

    mkdir -p "${PROJECT_DIR}" || die "Cannot create project dir"
    cd "${PROJECT_DIR}" || die "cd failed"

    # pom.xml
    write_file_atomic "pom.xml" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>${GROUP_ID}</groupId>
    <artifactId>${ARTIFACT_ID}</artifactId>
    <version>${VERSION}</version>
    <packaging>jar</packaging>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>${SPRINGBOOT_VER}</version>
        <relativePath/>
    </parent>

    <properties>
        <java.version>1.8</java.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
EOF

    # Main class
    mkdir -p "src/main/java/com/example"
    write_file_atomic "src/main/java/com/example/${CLASS_NAME}.java" <<EOF
package com.example;

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootApplication
@RestController
public class ${CLASS_NAME} {

    public static void main(String[] args) {
        SpringApplication.run(${CLASS_NAME}.class, args);
    }

    @GetMapping("/")
    public String home() {
        return "Hello from Spring Boot ${SPRINGBOOT_VER}!<br/>\\n" +
               "Running on Java 8 (Amazon Corretto)<br/>\\n";
    }
}
EOF

    # properties
    mkdir -p "src/main/resources"
    write_file_atomic "src/main/resources/application.properties" <<EOF
server.port=${PORT}
server.address=${BIND_IP}
EOF

    info "Project created."
}

build_and_run() {
    info "Building..."

    mvn clean package -DskipTests || {
        warn "Build failed. Try debugging:"
        printf "  cd \"%s\" && mvn clean package\n" "${PROJECT_DIR}"
        exit 1
    }

    printf "\n==============================================================\n"
    printf "  Spring Boot %s app starting...\n" "${SPRINGBOOT_VER}"
    printf "  → Open: http://localhost:%s/\n" "${PORT}"
    printf "  → Ctrl+C to stop\n"
    printf "==============================================================\n\n"

    exec java -jar "target/${JAR_NAME}"
}

main() {
    detect_install_locations
    parse_arguments "$@"

    if ! is_installed; then
        perform_self_install
    fi

    case "${COMMAND}" in
        version)  printf "%s version %s\n" "${APP_NAME}" "${APP_VER}"; exit 0 ;;
        help)     show_help; exit 0 ;;
        run)      ;;
        *)        die "Invalid command" ;;
    esac

    printf "\n"
    printf "==============================================================\n"
    printf "  %s v%s  –  SDKMAN + Java 8 Corretto + Maven + Spring Boot 2.7\n" "${APP_NAME}" "${APP_VER}"
    printf "==============================================================\n\n"

    setup_sdkman
    setup_java
    setup_maven
    setup_springboot_project
    build_and_run
}

main "$@"