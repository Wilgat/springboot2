#!/bin/bash
# =============================================================================
# springboot2 – version 1.4.0
# =============================================================================
#
# One-command installer + launcher for Spring Boot 2.7.x (last 2.x LTS)
#
#   • Installs itself (~/.local/bin or /usr/local/bin)
#   • Installs SDKMAN! with better multi-platform support
#   • Installs Java 8 Amazon Corretto + Maven
#   • (Re)creates & runs minimal Spring Boot 2.7.18 Hello World
#
# Install (user):
#     curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2 | bash
#
# Install (global):
#     curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot2/main/springboot2 | sudo bash
#
# GitHub: https://github.com/Wilgat/springboot2
#
# ────────────────────────────────────────────────
# STRICT CIAO DEFENSIVE CODING STYLE - FULLY APPLIED
# ────────────────────────────────────────────────
#
# !!! DO NOT MODIFY OR SIMPLIFY ANY PART OF THIS HEADER OR FUNCTIONS !!!
#
# Shebang is deliberately set to #!/bin/bash because SDKMAN requires Bash.
# Repeated safe defaults, redundant checks, and heavy comments are intentional.
#
# Aligned with https://github.com/Wilgat/ciao
# Last aligned: April 2026
# =============================================================================

APP_NAME="springboot2"
APP_VER="1.4.0"

REPO_USER="Wilgat"
REPO_NAME="springboot2"
SCRIPT_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/main/${APP_NAME}"

# ────────────────────────────────────────────────
# Safe variable defaults — repeated on purpose
# ────────────────────────────────────────────────

: "${GLOBAL_BIN:=/usr/local/bin}"
: "${USER_BIN:=${HOME}/.local/bin}"

: "${PROJECT_NAME:=springboot-${APP_NAME}}"
: "${PROJECT_DIR:=${HOME}/${PROJECT_NAME}}"

: "${JAVA_ID:=8.0.472-amzn}"
: "${MAVEN_VER:=3.9.9}"
: "${SPRINGBOOT_VER:=2.7.18}"
: "${ARTIFACT_ID:=hello-${APP_NAME}}"
: "${CLASS_NAME:=HelloApplication}"
: "${GROUP_ID:=com.example}"
: "${VERSION:=0.0.1}"
: "${JAR_NAME:=${ARTIFACT_ID}-${VERSION}.jar}"
: "${PORT:=8080}"
: "${BIND_IP:=0.0.0.0}"

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

die() { printf >&2 "${RED}Error: %s${NC}\n" "$*"; exit 1; }
info() { printf "${GREEN}→ %s${NC}\n" "$*"; }
warn() { printf "${YELLOW}⚠  %s${NC}\n" "$*"; }

# =============================================================================
# is_installed() - Robust installation check
# =============================================================================
#
# GENERAL PURPOSE:
# Checks whether ciao is already installed, supporting both root
# and normal user installations with safe fallbacks.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

is_installed() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${APP_NAME:=ciao}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ -z "${IS_ROOT:-}" ]; then
        if [ "$(id -u)" -eq 0 ]; then
            IS_ROOT=1
        else
            IS_ROOT=0
        fi
    fi

    # Support explicit parameters or force flags
    if [ "${1:-}" = "--user" ] || [ "${FORCE_USER:-0}" -eq 1 ]; then
        [ -f "${USER_BIN}/${APP_NAME}" ] && [ -x "${USER_BIN}/${APP_NAME}" ] && return 0
        return 1
    elif [ "${1:-}" = "--global" ] || [ "${FORCE_GLOBAL:-0}" -eq 1 ]; then
        [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ] && return 0
        return 1
    fi

    # Main logic
    if [ "$IS_ROOT" -eq 1 ]; then
        [ -f "${INSTALL_PATH}" ] && [ -x "${INSTALL_PATH}" ]
    else
        { [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; } ||
        { [ -f "${USER_BIN}/${APP_NAME}"   ] && [ -x "${USER_BIN}/${APP_NAME}"   ]; }
    fi
}

# =============================================================================
# get_installed_version() - Extract version from installed binary
# =============================================================================
#
# GENERAL PURPOSE:
# Safely reads the VERSION constant from the installed ciao script.
# Used by --version-check and --self-update.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Designed to be reusable in other Wilgat projects.
# =============================================================================

get_installed_version() {
    local bin_path

    if [ "$IS_ROOT" -eq 1 ] || [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; then
        bin_path="${GLOBAL_BIN}/${APP_NAME}"
    else
        bin_path="${USER_BIN}/${APP_NAME}"
    fi

    if [ -x "$bin_path" ]; then
        # Extract VERSION line safely (POSIX compatible, works in BusyBox ash)
        grep '^VERSION="' "$bin_path" 2>/dev/null | cut -d'"' -f2 || echo "unknown"
    else
        echo "not installed"
    fi
}

# =============================================================================
# version_check() - Compare local vs remote version + suggest install
# =============================================================================
#
# GENERAL PURPOSE:
# Fetches the latest version from GitHub raw and compares with installed one.
# If not installed and running in interactive terminal, it suggests installation.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

version_check() {
    info "Checking latest version of ${APP_NAME}..."

    local remote_version
    remote_version=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$remote_version" ]; then
        error "Failed to fetch remote version"
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    printf "Local version : %s\n" "$local_version"
    printf "Latest version: %s\n\n" "$remote_version"

    if [ "$local_version" = "$remote_version" ]; then
        success "You are running the latest version."
        return 0
    elif [ "$local_version" = "not installed" ]; then
        warn "${APP_NAME} is not installed yet."
    else
        warn "A newer version is available (${remote_version})"
    fi

    # Automatically suggest installation if nothing is installed (interactive only)
    if ! is_installed && [ -t 0 ] && [ -t 1 ]; then
        printf "\nWould you like to install ${APP_NAME} now? (y/N): "
        read -r answer || true
        case "$answer" in
            [Yy]*|[Yy][Ee][Ss]*)
                FORCE_REINSTALL=1
                perform_self_install
                ;;
            *)
                printf "Installation skipped by user.\n"
                ;;
        esac
    fi
}

# =============================================================================
# self_update() - Perform self-update to latest version
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads and installs the latest version from GitHub.
# Respects --force and --quiet.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

self_update() {
    info "Starting self-update of ${APP_NAME}..."

    local remote_version
    remote_version=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$remote_version" ]; then
        error "Failed to fetch latest version"
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    if [ "$local_version" = "$remote_version" ] && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        success "Already running the latest version (${remote_version})."
        return 0
    fi

    if [ "$local_version" != "$remote_version" ]; then
        info "Updating from ${local_version} → ${remote_version}"
    fi

    FORCE_REINSTALL=1
    perform_self_install
}

# =============================================================================
# in_path() - Check if a directory is in $PATH
# =============================================================================
#
# GENERAL PURPOSE:
# Returns 0 if the given directory (default: INSTALL_DIR) is already in $PATH.
# POSIX-compatible using case statement (works in sh/dash/bash/zsh).
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

in_path() {
    case ":${PATH}:" in
        *:"${1:-$USER_BIN}":*) return 0 ;;
        *) return 1 ;;
    esac
}

# =============================================================================
# add_to_shell_path() - Multi-shell PATH support (bash + zsh + fish)
# =============================================================================
#
# GENERAL PURPOSE:
# Adds ~/.local/bin to the user's shell configuration for bash, zsh, and fish.
# Works even if the user is currently using a different shell.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

add_to_shell_path() {
    local added=0

    # Bash
    local bashrc="${HOME}/.bashrc"
    if [ -f "$bashrc" ]; then
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$bashrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$bashrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$bashrc"
            added=1
        fi
    fi

    # Zsh
    local zshrc="${HOME}/.zshrc"
    if [ -f "$zshrc" ]; then
        if ! grep -qF 'export PATH="$HOME/.local/bin:$PATH"' "$zshrc" 2>/dev/null; then
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$zshrc"
            printf 'export PATH="$HOME/.local/bin:$PATH"\n' >> "$zshrc"
            added=1
        fi
    fi

    # Fish
    local fish_config="${HOME}/.config/fish/config.fish"
    if [ -d "${HOME}/.config/fish" ] || mkdir -p "${HOME}/.config/fish" 2>/dev/null; then
        if [ -f "$fish_config" ] && grep -qF 'set -gx PATH $HOME/.local/bin $PATH' "$fish_config" 2>/dev/null; then
            : # already present
        else
            printf "\n# Added by %s installer (%s)\n" "$APP_NAME" "$VERSION" >> "$fish_config"
            printf 'set -gx PATH $HOME/.local/bin $PATH\n' >> "$fish_config"
            added=1
        fi
    fi

    if [ "$added" -eq 1 ]; then
        printf "${YELLOW}→ Added ~/.local/bin to PATH for bash/zsh/fish${NC}\n"
        printf "${YELLOW}→ Restart your terminal or run: source <your config file>${NC}\n"
    fi
}

# =============================================================================
# perform_self_install() - Main self-installation logic
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads and installs ciao to the correct location (global or user-local).
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

perform_self_install() {
    info "Starting installation of ${APP_NAME} ${VERSION}..."

    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        success "${APP_NAME} is already installed. Use --force or --reinstall to override."
        return 0
    fi

    # Determine install location
    if [ "$IS_ROOT" -eq 1 ]; then
        INSTALL_DIR="${GLOBAL_BIN}"
        INSTALL_PATH="${GLOBAL_BIN}/${APP_NAME}"
    else
        INSTALL_DIR="${USER_BIN}"
        INSTALL_PATH="${USER_BIN}/${APP_NAME}"
    fi

    # Create directory
    if ! mkdir -p "${INSTALL_DIR}" 2>/dev/null; then
        error "Failed to create ${INSTALL_DIR}"
        error "Try running with sudo or --user flag"
        return 1
    fi

    # Download to temporary file (secure mktemp)
    local tmp_file
    tmp_file=$(mktemp -t "${APP_NAME}.XXXXXX") || {
        error "Failed to create temporary file"
        return 1
    }

    info "Downloading ${APP_NAME} from GitHub..."

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "${SCRIPT_URL}" -o "${tmp_file}" || {
            error "Download failed (curl)"
            rm -f "${tmp_file}"
            return 1
        }
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "${tmp_file}" "${SCRIPT_URL}" || {
            error "Download failed (wget)"
            rm -f "${tmp_file}"
            return 1
        }
    else
        error "Neither curl nor wget found"
        rm -f "${tmp_file}"
        return 1
    fi

    # chmod +x is unreliable on Git Bash (Windows), but shebang usually suffices
    chmod +x "${tmp_file}" 2>/dev/null || warn "chmod +x failed (common on Git Bash / Windows - shebang should still allow execution)"

    rm -f "${INSTALL_PATH}" 2>/dev/null
    if ! mv "${tmp_file}" "${INSTALL_PATH}" 2>/dev/null; then
        error "Failed to move to ${INSTALL_PATH}"
        rm -f "${tmp_file}"
        return 1
    fi

    success "${APP_NAME} ${VERSION} successfully installed to ${INSTALL_PATH}"

    # PATH guidance for normal users
    if [ "$IS_ROOT" -eq 0 ]; then
        if ! in_path; then
            add_to_shell_path
        else
            success "${APP_NAME} is now available in your PATH"
        fi
    else
        success "You can now run: ${APP_NAME}"
    fi

    return 0
}

# =============================================================================
# maybe_install() - Friendly installation prompt
# =============================================================================
#
# GENERAL PURPOSE:
# Called when ciao is not installed. Shows helpful message and asks for confirmation.
#
# !!! DO NOT MODIFY OR SIMPLIFY !!!
# =============================================================================

maybe_install() {
    if is_installed && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        return 0
    fi

    printf "\n"
    printf "${YELLOW}Note: '%s' is not installed yet.${NC}\n" "$APP_NAME"
    printf "     Version: ${VERSION}\n\n"
    printf "Recommended installation command:\n\n"

    if [ "$IS_ROOT" -eq 1 ]; then
        printf "     ${GREEN}sudo curl -fsSL %s | sudo sh${NC}\n" "$SCRIPT_URL"
    else
        printf "     ${GREEN}curl -fsSL %s | sh${NC}\n" "$SCRIPT_URL"
    fi
    printf "\n"

    local should_install=false

    if [ -t 0 ] && [ -t 1 ]; then
        # Interactive terminal
        printf "     Install now? (y/N): "
        read -r answer || true
        case "$answer" in
            [Yy]*|[Yy][Ee][Ss]*) should_install=true ;;
            *) printf "Installation skipped by user.\n"; return 0 ;;
        esac
    else
        # Non-interactive (curl | sh, scripts, CI, etc.)
        printf "${YELLOW}Non-interactive mode detected → installing automatically...${NC}\n"
        should_install=true
    fi

    if [ "$should_install" = "true" ]; then
        perform_self_install
        exit 0
    fi
}

# =============================================================================
# check_alpine_requirements()
# =============================================================================
check_alpine_requirements() {
    if [ -f "/etc/alpine-release" ]; then
        info "Alpine Linux detected."
        if ! command -v bash >/dev/null 2>&1; then
            warn "bash is required for SDKMAN! on Alpine Linux."
            printf "\nPlease install bash first:\n"
            printf "    ${GREEN}apk add bash${NC}\n\n"
            printf "Then re-run this script with:\n"
            printf "    ${GREEN}bash <(curl -fsSL ${SCRIPT_URL})${NC}\n"
            exit 1
        fi
    fi
}

# =============================================================================
# setup_sdkman()
# =============================================================================
setup_sdkman() {
    info "Checking SDKMAN..."

    check_alpine_requirements

    if [ -d "${HOME}/.sdkman" ] && command -v sdk >/dev/null 2>&1; then
        info "SDKMAN already installed."
        return 0
    fi

    info "Installing SDKMAN..."
    curl -s "https://get.sdkman.io" | bash || die "SDKMAN install failed"

    local init="${HOME}/.sdkman/bin/sdkman-init.sh"
    if [ -s "$init" ]; then
        . "$init"
    fi

    if ! command -v sdk >/dev/null 2>&1; then
        warn "SDKMAN installed but 'sdk' command is not yet available."
        printf "\nPlease run one of these commands, then retry:\n"
        printf "    ${GREEN}. \"${HOME}/.sdkman/bin/sdkman-init.sh\"${NC}\n"
        printf "    or simply open a new terminal\n\n"
        exit 1
    fi

    info "SDKMAN is ready."
}

setup_java() {
    info "Setting up Java 8 (Amazon Corretto)..."
    sdk install java "${JAVA_ID}" </dev/null || die "Java install failed"
    sdk default java "${JAVA_ID}" >/dev/null 2>&1
    sdk use java "${JAVA_ID}" >/dev/null 2>&1 || true
    java -version 2>&1 | head -n 1 || die "Java not working"
}

setup_maven() {
    info "Setting up Maven ${MAVEN_VER}..."
    sdk install maven "${MAVEN_VER}" </dev/null || die "Maven install failed"
    sdk default maven "${MAVEN_VER}" >/dev/null 2>&1
    sdk use maven "${MAVEN_VER}" >/dev/null 2>&1 || true
    mvn --version | head -n 3 || die "Maven not working"
}

write_file_atomic() {
    local target="$1"
    local tmp
    tmp=$(mktemp "${target}.XXXXXXXX") || die "mktemp failed"

    cat > "${tmp}" || { rm -f "${tmp}"; die "write failed"; }
    mv "${tmp}" "${target}" || { rm -f "${tmp}"; die "mv failed → ${target}"; }
}

setup_springboot_project() {
    info "Preparing Spring Boot ${SPRINGBOOT_VER} demo → ${PROJECT_DIR}"

    if [ -d "${PROJECT_DIR}" ]; then
        info "Removing old project folder..."
        rm -rf "${PROJECT_DIR}"
    fi

    mkdir -p "${PROJECT_DIR}" || die "Cannot create project dir"
    cd "${PROJECT_DIR}" || die "cd failed"

    write_file_atomic "pom.xml" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>hello-springboot2</artifactId>
    <version>0.0.1</version>
    <packaging>jar</packaging>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>2.7.18</version>
        <relativePath/>
    </parent>
    <properties>
        <java.version>1.8</java.version>
    </properties>
    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>
    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
EOF

    mkdir -p "src/main/java/com/example"
    write_file_atomic "src/main/java/com/example/HelloApplication.java" <<'EOF'
package com.example;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootApplication
@RestController
public class HelloApplication {
    public static void main(String[] args) {
        SpringApplication.run(HelloApplication.class, args);
    }
    @GetMapping("/")
    public String home() {
        return "Hello from Spring Boot 2.7.18!<br/>Running on Java 8 (Amazon Corretto)";
    }
}
EOF

    mkdir -p "src/main/resources"
    write_file_atomic "src/main/resources/application.properties" <<EOF
server.port=${PORT}
server.address=${BIND_IP}
EOF

    info "Spring Boot project created successfully."
}

build_and_run() {
    info "Building project..."
    mvn clean package -DskipTests || {
        warn "Build failed."
        printf "Debug: cd \"%s\" && mvn clean package\n" "${PROJECT_DIR}"
        exit 1
    }

    printf "\n==============================================================\n"
    printf "  Spring Boot %s is starting...\n" "${SPRINGBOOT_VER}"
    printf "  → Open: http://localhost:%s/\n" "${PORT}"
    printf "  → Ctrl+C to stop\n"
    printf "==============================================================\n\n"

    exec java -jar "target/${JAR_NAME}"
}

show_help() {
    cat <<EOF
${APP_NAME} v${APP_VER} — Spring Boot 2.7.x quick setup

Usage:
  ${APP_NAME}                 Setup + build + run
  ${APP_NAME} version         Show version
  ${APP_NAME} version-check   Compare with latest
  ${APP_NAME} self-update     Update to latest
  ${APP_NAME} help            This help
EOF
}

parse_arguments() {
    COMMAND="run"
    while [ $# -gt 0 ]; do
        case "$1" in
            help|--help|-h)                    COMMAND="help" ;;
            version|--version)                 COMMAND="version" ;;
            version-check|--version-check)     COMMAND="version-check" ;;
            self-update|--self-update)         COMMAND="self-update" ;;
            *) warn "Unknown argument: $1"; show_help; exit 1 ;;
        esac
        shift
    done
}

main() {
    : "${HOME:=/root}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"

    detect_install_locations
    parse_arguments "$@"

    if ! is_installed; then
        maybe_install
    fi

    case "${COMMAND}" in
        version)         printf "%s version %s\n" "${APP_NAME}" "${APP_VER}"; exit 0 ;;
        version-check)   version_check; exit 0 ;;
        self-update)     self_update; exit 0 ;;
        help)            show_help; exit 0 ;;
        run)             ;;
        *)               die "Invalid command" ;;
    esac

    printf "\n==============================================================\n"
    printf "  %s v%s  –  SDKMAN + Java 8 + Maven + Spring Boot 2.7\n" "${APP_NAME}" "${APP_VER}"
    printf "==============================================================\n\n"

    setup_sdkman
    setup_java
    setup_maven
    setup_springboot_project
    build_and_run
}

main "$@"